# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# claude code local settings (per-user, per-machine)
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# context window config (user-specific)
context-windows.json

# prisma
prisma/dev.db
prisma/dev.db-journal

# test data (large files)
tests/data/opencode-sessions.db
tests/data/opencode-sessions.db-shm
tests/data/opencode-sessions.db-wal
# e2e fixture db is rebuilt from opencode-sample.sql at test time (OAT: no binary)
tests/data/e2e/opencode-sample.db
tests/data/e2e/opencode-sample.db-shm
tests/data/e2e/opencode-sample.db-wal

# favicon: use src/app/icon.svg (text) instead of binary .ico (OAT: no binary)
src/app/favicon.ico

# logs (large DB files)
logs/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# package lock (regenerated by npm install, platform-specific)
package-lock.json

# dev docs (temporary logs/reports)
docs/dev-log.md
docs/report.md
