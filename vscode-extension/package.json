{
  "name": "cannbot-insight",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.7.0",
  "publisher": "hismartlite",
  "repository": {
    "type": "git",
    "url": "https://github.com/newbietk/agent-insight"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onCommand:hismartlite.import",
    "onCommand:hismartlite.refreshSessions",
    "onCommand:hismartlite.openSession",
    "onCommand:hismartlite.deleteSession",
    "onCommand:hismartlite.syncSession",
    "onCommand:hismartlite.syncAll",
    "onView:hismartlite.sessions"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hismartlite.import",
        "title": "%command.import.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "hismartlite.refreshSessions",
        "title": "%command.refreshSessions.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "hismartlite.openSession",
        "title": "%command.openSession.title%",
        "icon": "$(eye)"
      },
      {
        "command": "hismartlite.deleteSession",
        "title": "%command.deleteSession.title%",
        "icon": "$(trash)"
      },
      {
        "command": "hismartlite.syncSession",
        "title": "%command.syncSession.title%",
        "icon": "$(sync)"
      },
      {
        "command": "hismartlite.syncAll",
        "title": "%command.syncAll.title%",
        "icon": "$(sync~spin)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hismartlite",
          "title": "%viewContainer.title%",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "hismartlite": [
        {
          "id": "hismartlite.sessions",
          "name": "%view.sessions.name%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "hismartlite.import",
          "when": "view == hismartlite.sessions",
          "group": "navigation"
        },
        {
          "command": "hismartlite.refreshSessions",
          "when": "view == hismartlite.sessions",
          "group": "navigation"
        },
        {
          "command": "hismartlite.syncAll",
          "when": "view == hismartlite.sessions",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "hismartlite.openSession",
          "when": "view == hismartlite.sessions",
          "group": "inline"
        },
        {
          "command": "hismartlite.syncSession",
          "when": "view == hismartlite.sessions",
          "group": "inline"
        },
        {
          "command": "hismartlite.deleteSession",
          "when": "view == hismartlite.sessions"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "hismartlite.claudeProjectsPath": {
          "type": "string",
          "default": "",
          "description": "%config.claudeProjectsPath.description%"
        },
        "hismartlite.cloudUrl": {
          "type": "string",
          "default": "http://localhost:21026",
          "description": "%config.cloudUrl.description%"
        },
        "hismartlite.autoSync.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoSync.enabled.description%"
        },
        "hismartlite.autoSync.intervalMs": {
          "type": "number",
          "default": 30000,
          "description": "%config.autoSync.intervalMs.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-assets",
    "compile": "tsc -p ./",
    "copy-assets": "node -e \"const fs=require('fs');const p='src/media';fs.readdirSync(p).filter(f=>/\\.(png|svg)$/.test(f)).forEach(f=>{const d='out/media';if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p+'/'+f,d+'/'+f);console.log('Copied '+f)});\"",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
